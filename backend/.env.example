# Base de datos PostgreSQL (Railway te da esta URL automáticamente)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT - genera una clave larga y aleatoria
JWT_SECRET="cambia-esto-por-una-clave-secreta-muy-larga-32chars"
JWT_EXPIRES_IN="7d"

# Puerto del servidor
PORT=3001

# URL del frontend (para CORS)
FRONTEND_URL="http://localhost:5173"
